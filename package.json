{
  "name": "aub",
  "version": "0.3.0",
  "description": "UI Blueprint Agent — structured spec format for AI coding agents",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "workspace:start": "node packages/workspace-cli/bin/aub-workspace.mjs",
    "workspace:package": "pnpm --dir apps/mcp-server build && pnpm --dir apps/editor build && pnpm --dir packages/workspace-cli pack --pack-destination ../../dist",
    "validate": "node scripts/validate.mjs",
    "scaffold": "node scripts/scaffold-blueprint.mjs",
    "project": "node scripts/project.mjs",
    "gen": "node scripts/generate-registry-artifacts.mjs",
    "gen:check": "node scripts/generate-registry-artifacts.mjs --check",
    "migrate": "node scripts/migrate-blueprint-cli.mjs",
    "diff": "node scripts/diff-blueprint.mjs",
    "prompt": "node scripts/export-agent-prompt.mjs",
    "report:init": "node scripts/create-implementation-report.mjs",
    "report:verify": "node scripts/verify-implementation-report.mjs",
    "ci:verify": "node scripts/ci-verify.mjs",
    "score:agent": "node scripts/score-agent-readability.mjs",
    "benchmark:agent": "node scripts/run-agent-readability.mjs",
    "benchmark:implementation": "node scripts/run-agent-implementation.mjs",
    "score:implementation": "node scripts/score-agent-implementation.mjs",
    "usage:cost-benchmark": "node scripts/usage-cost-benchmark.mjs",
    "import:angular": "node scripts/import-angular-component.mjs",
    "import:design": "node scripts/import-design-bridge.mjs",
    "authoring:kit": "node scripts/create-authoring-kit.mjs",
    "brand:sync": "node scripts/sync-brand-assets.mjs",
    "site:locales": "node scripts/generate-site-locales.mjs",
    "site:locales:check": "node scripts/generate-site-locales.mjs --check",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "parse5": "^7.2.1",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
