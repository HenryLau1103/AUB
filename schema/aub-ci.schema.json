{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://henrylau1103.github.io/AUB/schema/aub-ci.schema.json",
  "title": "AUB CI Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "1.0.0" },
    "discover": {
      "type": "boolean",
      "description": "When true, merge discovered .ui.json/.ui.yaml/*.aub.project files with the explicit lists."
    },
    "blueprints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "projects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blueprint", "report"],
        "properties": {
          "blueprint": { "type": "string", "minLength": 1 },
          "report": { "type": "string", "minLength": 1 }
        }
      }
    },
    "min_safety_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Optional minimum implementation safety score required for configured reports."
    }
  }
}
