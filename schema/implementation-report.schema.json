{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aub.dev/schema/implementation-report/1.0.0",
  "title": "AUB Implementation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "format_version",
    "blueprint",
    "implementation",
    "node_mappings",
    "acceptance_results",
    "unresolved"
  ],
  "properties": {
    "format": { "const": "aub-implementation-report" },
    "format_version": { "const": "1.0.0" },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screen_id", "version"],
      "properties": {
        "screen_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "route", "files"],
      "properties": {
        "framework": { "type": "string" },
        "route": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "node_mappings": {
      "type": "array",
      "items": { "$ref": "#/$defs/nodeMapping" }
    },
    "acceptance_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/acceptanceResult" }
    },
    "unresolved": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "nodeMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "status", "component"],
      "properties": {
        "node_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["mapped", "unmapped"] },
        "component": { "type": "string" },
        "file": { "type": "string" },
        "selector": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "acceptanceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance_id", "status", "evidence"],
      "properties": {
        "acceptance_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "fail", "needs-review"] },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "notes": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "enum": [
            "screenshot",
            "file",
            "dom",
            "dom_query",
            "computed_style",
            "overflow",
            "component_reuse",
            "command",
            "interaction",
            "code_diff",
            "note"
          ]
        },
        "reference": { "type": "string", "minLength": 1 },
        "viewport": { "type": "string" },
        "selector": { "type": "string" },
        "expected": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "actual": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "bytes": { "type": "integer", "minimum": 0 },
        "pass": { "type": "boolean" }
      }
    }
  }
}
