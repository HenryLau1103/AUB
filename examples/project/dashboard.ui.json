{
  "$schema": "../../schema/ui-blueprint.schema.json",
  "version": "0.3.0",
  "screen": {
    "id": "acme.dashboard",
    "name": "Dashboard",
    "type": "dashboard",
    "platform": "web",
    "primary_user_goal": "Let the user review key metrics and open settings."
  },
  "viewports": [
    {
      "id": "desktop",
      "width": 1440,
      "height": 900
    },
    {
      "id": "tablet",
      "width": 1024,
      "height": 768
    },
    {
      "id": "mobile",
      "width": 390,
      "height": 844
    }
  ],
  "design_system": {
    "name": "Acme Tokens",
    "colors": {
      "primary": "#2563eb",
      "surface": "#ffffff",
      "text": "#0f172a"
    },
    "typography": {
      "base_font": "Inter",
      "scale": "1.25"
    },
    "spacing": {
      "space.1": "4px",
      "space.2": "8px",
      "space.3": "16px"
    },
    "radii": {
      "radius.control": "6px",
      "radius.panel": "8px"
    },
    "shadows": {
      "shadow.card": "0 1px 2px rgba(0,0,0,0.06)"
    }
  },
  "nodes": [
    {
      "id": "shell",
      "type": "app_shell",
      "name": "App Shell",
      "role": "Top-level layout container for the dashboard.",
      "parent_id": null,
      "children": [
        "top_bar",
        "metrics"
      ],
      "layout": {
        "mode": "auto",
        "display": "flex",
        "direction": "column"
      }
    },
    {
      "id": "top_bar",
      "type": "top_bar",
      "name": "Top Bar",
      "role": "Holds the settings entry point.",
      "parent_id": "shell",
      "children": [
        "settings_btn"
      ],
      "layout": {
        "mode": "auto",
        "display": "flex",
        "direction": "row"
      },
      "placements": {
        "desktop": {
          "x": 0,
          "y": 0,
          "width": 1440,
          "height": 64,
          "z_index": 2
        },
        "tablet": {
          "x": 0,
          "y": 0,
          "width": 1024,
          "height": 64,
          "z_index": 2
        },
        "mobile": {
          "x": 0,
          "y": 0,
          "width": 390,
          "height": 64,
          "z_index": 2
        }
      }
    },
    {
      "id": "settings_btn",
      "type": "icon_button",
      "name": "Settings",
      "role": "Opens the settings screen.",
      "parent_id": "top_bar",
      "children": [],
      "content": {
        "action": "navigate:acme.settings",
        "icon": "settings"
      },
      "placements": {
        "desktop": {
          "x": 1380,
          "y": 10,
          "width": 44,
          "height": 44,
          "z_index": 3
        },
        "tablet": {
          "x": 1380,
          "y": 10,
          "width": 44,
          "height": 44,
          "z_index": 3
        },
        "mobile": {
          "x": 1380,
          "y": 10,
          "width": 44,
          "height": 44,
          "z_index": 3
        }
      }
    },
    {
      "id": "metrics",
      "type": "section",
      "name": "Metrics",
      "role": "Shows headline metrics.",
      "parent_id": "shell",
      "children": [
        "metric_a",
        "metric_b"
      ],
      "layout": {
        "mode": "auto",
        "display": "grid",
        "grid": {
          "columns": 2,
          "rows": 1
        }
      },
      "placements": {
        "desktop": {
          "x": 0,
          "y": 64,
          "width": 1440,
          "height": 300,
          "z_index": 1
        },
        "tablet": {
          "x": 0,
          "y": 64,
          "width": 1024,
          "height": 300,
          "z_index": 1
        },
        "mobile": {
          "x": 0,
          "y": 64,
          "width": 390,
          "height": 300,
          "z_index": 1
        }
      }
    },
    {
      "id": "metric_a",
      "type": "metric_card",
      "name": "Revenue",
      "role": "Displays revenue metric.",
      "parent_id": "metrics",
      "children": [],
      "placements": {
        "desktop": {
          "x": 40,
          "y": 100,
          "width": 640,
          "height": 160,
          "z_index": 2
        },
        "tablet": {
          "x": 40,
          "y": 100,
          "width": 640,
          "height": 160,
          "z_index": 2
        },
        "mobile": {
          "x": 40,
          "y": 100,
          "width": 390,
          "height": 160,
          "z_index": 2
        }
      }
    },
    {
      "id": "metric_b",
      "type": "metric_card",
      "name": "Users",
      "role": "Displays active users metric.",
      "parent_id": "metrics",
      "children": [],
      "placements": {
        "desktop": {
          "x": 720,
          "y": 100,
          "width": 640,
          "height": 160,
          "z_index": 2
        },
        "tablet": {
          "x": 720,
          "y": 100,
          "width": 640,
          "height": 160,
          "z_index": 2
        },
        "mobile": {
          "x": 720,
          "y": 100,
          "width": 390,
          "height": 160,
          "z_index": 2
        }
      }
    }
  ],
  "interactions": [
    {
      "id": "interaction_1",
      "trigger": "click",
      "source_node_id": "settings_btn",
      "action": "navigate:acme.settings",
      "result_state": "The result of Settings is visibly presented to the user."
    }
  ],
  "responsive": [
    {
      "viewport": "tablet",
      "rule": "icon_only",
      "target_node_id": "top_bar",
      "changes": {}
    },
    {
      "viewport": "tablet",
      "rule": "col_reduce",
      "target_node_id": "metrics",
      "changes": {
        "columns": 2
      }
    },
    {
      "viewport": "mobile",
      "rule": "bottom_nav",
      "target_node_id": "top_bar",
      "changes": {}
    },
    {
      "viewport": "mobile",
      "rule": "col_reduce",
      "target_node_id": "metrics",
      "changes": {
        "columns": 1
      }
    }
  ],
  "acceptance": [
    {
      "id": "acc_1",
      "type": "layout",
      "statement": "All major regions match their declared placements on desktop.",
      "target": "desktop",
      "priority": "blocker",
      "verification_method": "screenshot_diff"
    },
    {
      "id": "acc_2",
      "type": "interaction",
      "statement": "Primary buttons and navigation controls declare and perform their actions.",
      "target": "*",
      "priority": "must",
      "verification_method": "interaction_replay"
    },
    {
      "id": "acc_3",
      "type": "responsive",
      "statement": "The tablet layout adapts without horizontal overflow.",
      "target": "tablet",
      "priority": "must",
      "verification_method": "screenshot_diff"
    },
    {
      "id": "acc_4",
      "type": "a11y",
      "statement": "Interactive controls have understandable labels and visible focus states.",
      "target": "*",
      "priority": "must",
      "verification_method": "axe_audit"
    },
    {
      "id": "acc_5",
      "type": "content",
      "statement": "Names and content explain the purpose of each major region starting at App Shell.",
      "target": "*",
      "priority": "should",
      "verification_method": "manual_ia_review"
    }
  ]
}
